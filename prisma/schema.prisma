// src/schema.prisma:
generator client {
  provider     = "prisma-client"
  output       = "../src/generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

enum RolUsuario {
  admin
  doctor
  recepcionista
}

enum EstadoCita {
  pendiente
  completada
  cancelada
}

model Paciente {
  id_paciente      Int      @id @default(autoincrement())
  fecha_nacimiento DateTime
  nombre           String
  direccion        String?
  email            String?  @unique
  telefono         String?

  citas Cita[]
}

model Especialidad {
  id_especialidad Int    @id @default(autoincrement())
  nombre          String @unique

  doctores Doctor[]
}

model Doctor {
  id_doctor Int     @id @default(autoincrement())
  nombre    String
  telefono  String?
  email     String? @unique

  id_especialidad Int
  especialidad    Especialidad @relation(fields: [id_especialidad], references: [id_especialidad])

  citas   Cita[]
  usuario Usuario?

  @@index([id_especialidad])
}

model Usuario {
  id_usuario Int        @id @default(autoincrement())
  username   String     @unique
  password   String
  rol        RolUsuario

  id_doctor Int?    @unique
  doctor    Doctor? @relation(fields: [id_doctor], references: [id_doctor])

  @@index([id_doctor])
}

model Cita {
  id_cita Int        @id @default(autoincrement())
  fecha   DateTime
  motivo  String
  estado  EstadoCita @default(pendiente)

  id_paciente Int
  paciente    Paciente @relation(fields: [id_paciente], references: [id_paciente])

  id_doctor Int
  doctor    Doctor @relation(fields: [id_doctor], references: [id_doctor])

  receta Receta?

  @@index([id_paciente])
  @@index([id_doctor])
  @@index([fecha])
}

model Receta {
  id_receta     Int      @id @default(autoincrement())
  fecha_emision DateTime @default(now())
  indicaciones  String?

  id_cita Int  @unique
  cita    Cita @relation(fields: [id_cita], references: [id_cita])

  medicamentos RecetaMedica[]

  @@index([id_cita])
  @@index([fecha_emision])
}

model Medicamento {
  id_medicamento Int     @id @default(autoincrement())
  nombre         String  @unique
  descripcion    String?

  recetas RecetaMedica[]
}

model RecetaMedica {
  id_receta Int
  receta    Receta @relation(fields: [id_receta], references: [id_receta])

  id_medicamento Int
  medicamento    Medicamento @relation(fields: [id_medicamento], references: [id_medicamento])

  dosis      String
  frecuencia String

  @@id([id_receta, id_medicamento])
  @@index([id_medicamento])
}
